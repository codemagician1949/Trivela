# Trivela Frontend Environment Configuration
# Copy this file to .env.local for local development if needed.

# Optional: Base URL used for frontend fetch calls.
# Leave unset to use the local Vite proxy (recommended for dev).
# VITE_API_URL=http://localhost:3001

# Optional: Explicit named preset (testnet or mainnet).
VITE_STELLAR_NETWORK=testnet

# Optional overrides for the selected network preset.
# VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# VITE_HORIZON_URL=https://horizon-testnet.stellar.org
# VITE_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Optional contract IDs (required only for on-chain actions).
# VITE_REWARDS_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
# VITE_CAMPAIGN_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Campaign detail polling interval in milliseconds (default 30000).
# VITE_POLL_INTERVAL_MS=30000

# Canonical site URL for SEO meta tags (defaults to window.location.origin).
# VITE_SITE_URL=https://trivela.example

